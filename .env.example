# CommandClaw — Environment Configuration
# Copy to .env and fill in your values.

# --- Required ---
COMMANDCLAW_OPENAI_API_KEY=sk-...
COMMANDCLAW_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# --- Vault / Workspace ---
# Agent ID determines workspace naming: cclaw-<agent-id>-<uuid>
# Workspaces live at ~/.commandclaw/workspaces/
COMMANDCLAW_AGENT_ID=default
# COMMANDCLAW_VAULT_TEMPLATE=/apps/commandclaw-vault
# COMMANDCLAW_REUSE_WORKSPACE=true
# Explicit vault path (skips workspace manager if set):
# COMMANDCLAW_VAULT_PATH=/path/to/vault

# --- LLM ---
# COMMANDCLAW_OPENAI_MODEL=gpt-4o
# COMMANDCLAW_OPENAI_TEMPERATURE=0.2
# COMMANDCLAW_OPENAI_BASE_URL=

# --- Telegram ---
# Comma-separated list of allowed chat IDs. Empty = allow all.
# COMMANDCLAW_TELEGRAM_ALLOWED_CHAT_IDS=[]
# COMMANDCLAW_TELEGRAM_CHUNK_SIZE=4000

# --- MCP Gateway (optional) ---
# COMMANDCLAW_MCP_GATEWAY_URL=http://localhost:8100
# COMMANDCLAW_MCP_AGENT_KEY=

# --- Langfuse (optional) ---
# COMMANDCLAW_LANGFUSE_PUBLIC_KEY=
# COMMANDCLAW_LANGFUSE_SECRET_KEY=
# COMMANDCLAW_LANGFUSE_HOST=https://cloud.langfuse.com

# --- Execution ---
# COMMANDCLAW_BASH_TIMEOUT=120
# COMMANDCLAW_MAX_RETRIES=3
# COMMANDCLAW_RETRY_BASE_DELAY=1.0

# --- Codex credential shortcut ---
# COMMANDCLAW_CODEX_HOME=~/.codex
